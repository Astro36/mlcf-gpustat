groups:
  - name: gpu
    interval: 10s
    eval_delay: 1s
    rules:
      - alert: GPUUsageEnded
        expr: |
          (gpu_memory_used <= 10)
          AND on(server_name, gpu_index)
          (min_over_time(gpu_memory_used[20s] offset 20s) > 10)
        for: 0s
        labels:
          severity: info
        annotations:
          title: "{{ $labels.server_name }} — GPU #{{ $labels.gpu_index }} 사용 완료"
          content: |
            {{- range query (printf "sort_desc(last_over_time(gpu_process_memory_used{server_name=%q,gpu_index=%q}[20s] offset 20s))" $labels.server_name $labels.gpu_index) -}}
            • {{ .Labels.user }} ({{ .Value | printf "%.0f" }}MB)
            {{ end -}}
